# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Required for live recommendations. Free, no credit card:
# https://www.themoviedb.org/settings/api -> "API Read Access Token (v4 auth)"
VITE_TMDB_TOKEN=

# Alternative to the token above (v3 api key). Only one is needed.
VITE_TMDB_KEY=

# Optional. Adds Rotten Tomatoes / Metacritic / IMDb scores as a secondary
# signal. Free key: https://www.omdbapi.com/apikey.aspx
VITE_OMDB_KEY=
